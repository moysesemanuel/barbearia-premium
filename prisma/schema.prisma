generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CANCELLED
  COMPLETED
}

model Barber {
  id           String        @id @default(cuid())
  name         String        @unique
  role         String
  active       Boolean       @default(true)
  appointments Appointment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Service {
  id              String        @id @default(cuid())
  name            String        @unique
  description     String
  priceInCents    Int
  durationMinutes Int
  active          Boolean       @default(true)
  appointments    Appointment[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model ClosedDate {
  id        String   @id @default(cuid())
  date      String   @unique
  reason    String
  createdAt DateTime @default(now())
}

model Appointment {
  id            String            @id @default(cuid())
  customerName  String
  customerPhone String
  notes         String?
  startsAt      DateTime
  endsAt        DateTime
  status        AppointmentStatus @default(SCHEDULED)
  barberId      String
  serviceId     String
  barber        Barber            @relation(fields: [barberId], references: [id], onDelete: Restrict)
  service       Service           @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([barberId, startsAt, endsAt])
  @@index([startsAt])
}
